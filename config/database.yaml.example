# DolphinDB 数据库配置
# 复制为 database.yaml 并填入实际配置

dolphindb:
  enabled: true
  
  # 连接配置
  connection:
    host: "localhost"
    port: 8848
    user: "admin"
    password: "${DOLPHINDB_PASSWORD}"  # 使用环境变量
    
  # 数据库配置
  databases:
    tushare:
      name: "dfs://tushare"
      description: "Tushare 股票数据"
      
    factors:
      name: "dfs://tushare_factors"
      description: "Alpha 因子数据"
    
  # 连接池配置
  pool:
    max_connections: 10
    connection_timeout: 30
    read_timeout: 60
