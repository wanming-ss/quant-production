# Tushare API 配置
# 复制为 tushare.yaml 并填入实际 Token
# 获取 Token: https://tushare.pro/user/token

tushare:
  enabled: true
  
  # API 配置
  api:
    token: "${TUSHARE_TOKEN}"  # 强烈建议使用环境变量
    base_url: "http://api.tushare.pro"
    timeout: 30
    
  # 频率限制（根据 Tushare 积分调整）
  rate_limit:
    # 基础积分（<2000）：每秒 1 次
    # 高级积分（>=2000）：每秒 5 次
    requests_per_second: 1
    daily_limit: 500000  # 每日最大调用次数
    
  # 数据缓存配置
  cache:
    enabled: true
    directory: "${PROJECT_ROOT}/data/cache"
    ttl_hours: 24  # 缓存有效期
    
  # 下载配置
  download:
    batch_size: 50000  # 每批记录数
    retry_times: 3
    retry_delay_seconds: 5
